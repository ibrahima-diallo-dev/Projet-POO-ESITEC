<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0" styleClass="content-pane"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sn.esitec.poo.cahiertexte.controller.EnseignantController">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <children>
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <padding><Insets bottom="20.0" /></padding>
            <children>
                <VBox spacing="5.0">
                    <Label styleClass="title-text" text="Espace Enseignant" />
                    <Label styleClass="subtitle-text" text="Gérez vos cours et vos séances pédagogiques" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="generatePdfButton" styleClass="secondary-button" text="📄 Générer PDF" />
            </children>
        </HBox>

        <!-- TabPane principal -->
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" styleClass="tab-pane">

            <!-- ONGLET 1 : Mes Séances -->
            <Tab text="📋 Mes Séances">
                <VBox spacing="15.0" styleClass="content-pane">
                    <padding><Insets top="20.0" /></padding>
                    <children>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <TextField fx:id="filterSeancesField" promptText="Rechercher séance" prefWidth="200" />
                            <Button fx:id="addSeanceButton" styleClass="primary-button" text="+ Ajouter une séance" onAction="#openAddSeancePopup" />
                            <Button fx:id="modifierSeanceButton" styleClass="secondary-button" 
                                    text="✏ Modifier" disable="true" onAction="#openModifierSeancePopup" />
                            <Button fx:id="supprimerSeanceButton" styleClass="danger-button"
                                    text="🗑 Supprimer" disable="true" onAction="#handleSupprimerSeance" />
                        </HBox>

                        <VBox styleClass="table-container" VBox.vgrow="ALWAYS">
                            <TableView fx:id="seancesTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colDate" prefWidth="110.0" text="Date" />
                                    <TableColumn fx:id="colHeure" prefWidth="90.0" text="Heure" />
                                    <TableColumn fx:id="colDuree" prefWidth="80.0" text="Durée (h)" />
                                    <TableColumn fx:id="colContenu" prefWidth="350.0" text="Contenu pédagogique" />
                                    <TableColumn fx:id="colStatut" prefWidth="120.0" text="Statut" />
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                            </TableView>
                        </VBox>

                        <HBox alignment="CENTER_LEFT" styleClass="info-bar">
                            <Label styleClass="subtitle-text" text="Total heures validées : " />
                            <Label fx:id="totalHoursLabel" styleClass="user-name-label" text="0h" />
                        </HBox>
                    </children>
                </VBox>
            </Tab>

            <!-- ONGLET 2 : Mes Cours -->
            <Tab text="📚 Mes Cours">
                <VBox spacing="15.0" styleClass="content-pane">
                    <padding><Insets top="20.0" /></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="title-text" text="Liste de mes cours" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="refreshCoursButton" styleClass="secondary-button" text="🔄 Rafraîchir" />
                        </HBox>
                        <VBox styleClass="table-container" VBox.vgrow="ALWAYS">
                            <TableView fx:id="coursTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colCoursNom" prefWidth="250.0" text="Nom du cours" />
                                    <TableColumn fx:id="colCoursClasse" prefWidth="200.0" text="Classe" />
                                    <TableColumn fx:id="colCoursNbSeances" prefWidth="150.0" text="Nb Séances" />
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                            </TableView>
                        </VBox>
                    </children>
                </VBox>
            </Tab>

            <!-- ONGLET 3 : Suivi Pédagogique -->
            <Tab text="📊 Suivi Pédagogique">
                <VBox alignment="CENTER" spacing="30.0" styleClass="content-pane">
                    <padding><Insets top="40.0" /></padding>
                    <children>
                        <Label styleClass="title-text" text="Récapitulatif pédagogique" />

                        <HBox spacing="20.0" alignment="CENTER">
                            <VBox styleClass="stat-card" spacing="10.0" prefWidth="180.0" alignment="CENTER">
                                <Label styleClass="stat-icon" text="⏱" />
                                <Label fx:id="totalHeuresLabel" styleClass="stat-value" text="0h" />
                                <Label styleClass="stat-title" text="Heures effectuées" />
                            </VBox>
                            <VBox styleClass="stat-card" spacing="10.0" prefWidth="180.0" alignment="CENTER">
                                <Label styleClass="stat-icon" text="✅" />
                                <Label fx:id="seancesValideesLabel" styleClass="stat-value" text="0" />
                                <Label styleClass="stat-title" text="Séances validées" />
                            </VBox>
                            <VBox styleClass="stat-card" spacing="10.0" prefWidth="180.0" alignment="CENTER">
                                <Label styleClass="stat-icon" text="⏳" />
                                <Label fx:id="seancesAttenteLabel" styleClass="stat-value" text="0" />
                                <Label styleClass="stat-title" text="En attente" />
                            </VBox>
                        </HBox>

                        <Button fx:id="generatePdfButton2" styleClass="primary-button" 
                                text="📄 Générer ma fiche de suivi PDF" onAction="#handleGeneratePdf" />
                    </children>
                </VBox>
            </Tab>

        </TabPane>
    </children>
</VBox>